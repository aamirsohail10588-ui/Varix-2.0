generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                        String                     @id @default(uuid())
  name                      String
  industry                  String?                    @default("Technology")
  company_size              String?                    @default("Mid-Market")
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  accounts                  Account[]
  auditLogs                 AuditLog[]
  branches                  Branch[]
  closeCycles               CloseCycle[]
  closeTasks                CloseTask[]
  controlOverrides          ControlOverride[]
  controlSpecs              ControlSpec[]
  costCenters               CostCenter[]
  customers                 Customer[]
  dataQualityIssues         DataQualityIssue[]
  roles                     Role[]
  taxComponents             TaxComponent[]
  users                     UserTenantRole[]
  vendors                   Vendor[]
  apiKeys                   ApiKey[]
  budgets                   Budget[]
  changeEvents              ChangeEvent[]
  controlRuns               ControlRun[]
  eliminationJournals       EliminationJournal[]
  entities                  Entity[]
  erpConnectors             ErpConnector[]
  evidenceDocuments         EvidenceDocument[]
  healthIndices             FinancialHealthIndex[]
  forecastVersions          ForecastVersion[]
  graphEdges                GraphEdge[]
  graphNodes                GraphNode[]
  gstRecords                GstRecord[]
  gstValidations            GstValidation[]
  ingestionBatches          IngestionBatch[]
  intercompanyTransactions  IntercompanyTransaction[]
  ledgerEntries             LedgerEntry[]
  materializedLedgerMetrics MaterializedLedgerMetric[]
  riskMetrics               RiskMetric[]
  serviceAccounts           ServiceAccount[]
  sessions                  Session[]
  snapshots                 Snapshot[]
  syncJobs                  SyncJob[]
  varianceRecords           VarianceRecord[]
  vendorCompliance          VendorCompliance[]
  bankAccounts              BankAccount[]
  bankStatements            BankStatement[]
  reconciliationMatches     ReconciliationMatch[]
  reconciliationSessions    ReconciliationSession[]
  workflowRuns              WorkflowRun[]
  jobDefinitions            JobDefinition[]
  schemaRegistries          SchemaRegistry[]
  accountMaps               AccountMap[]
  conditioningLogs          ConditioningLog[]
  lineageTrails             LineageTrail[]
  periodLocks               PeriodLock[]
  integritySeals            IntegritySeal[]
  taxJurisdictions          TaxJurisdiction[]
  approvalWorkflows         ApprovalWorkflow[]
  approvalRequests          ApprovalRequest[]
  anomalyAlerts             AnomalyAlert[]
  investigations            Investigation[]
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String?
  mfaEnabled        Boolean            @default(false)
  mfaSecret         String?
  googleId          String?            @unique
  microsoftId       String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  auditLogs         AuditLog[]
  controlOverrides  ControlOverride[]
  taskApprovals     TaskApproval[]
  taskEvidence      TaskEvidence[]
  tenants           UserTenantRole[]
  evidenceDocuments EvidenceDocument[]
  ingestionBatches  IngestionBatch[]
  sessions          Session[]
  periodLocks       PeriodLock[] @relation("PeriodLockedBy")
  integritySeals    IntegritySeal[] @relation("SealedBy")
  approvalRequests  ApprovalRequest[] @relation("RequestedBy")
  approvalSteps     ApprovalStep[] @relation("Approver")
  investigations    Investigation[] @relation("InvestigationAssignee")
}

model Role {
  id          String           @id @default(uuid())
  name        String
  description String?
  tenantId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  users       UserTenantRole[]

  @@unique([name, tenantId])
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserTenantRole {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      Role     @relation(fields: [roleId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId, roleId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  tenantId     String?
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  deviceMeta   Json?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model ApiKey {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  keyHash   String    @unique
  prefix    String
  scopes    String[]  @default(["read"])
  expiresAt DateTime?
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@map("api_keys")
}

model ServiceAccount {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  clientId   String   @unique
  secretHash String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@map("service_accounts")
}

model Account {
  id        String        @id @default(uuid())
  tenantId  String
  code      String
  name      String
  type      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  entries   LedgerEntry[]
  accountMaps AccountMap[]
  budgetItems BudgetItem[]

  @@unique([tenantId, code])
}

model LedgerEntry {
  id                 String   @id @default(uuid())
  tenant_id          String
  transaction_date   DateTime
  posting_period     String?  @default("OPEN")
  account_id         String
  debit_amount       Decimal  @default(0.0) @db.Decimal(19, 4)
  credit_amount      Decimal  @default(0.0) @db.Decimal(19, 4)
  currency           String?  @default("USD")
  base_currency_amount Decimal? @default(0.0) @db.Decimal(19, 4)
  source_system      String?
  snapshot_id        String?
  createdAt          DateTime @default(now())
  confidence_score   Int?     @default(100)
  ingestion_batch_id String?
  raw_record_id      String?
  source_id          String?
  provenance_hash    String?   // SHA-256 for immutability proof
  tax_code           String?
  tax_amount         Decimal?  @default(0.0) @db.Decimal(19, 4)
  tax_rate_id        String?
  account            Account  @relation(fields: [account_id], references: [id])
  tenant             Tenant   @relation(fields: [tenant_id], references: [id])
  snapshot           Snapshot? @relation(fields: [snapshot_id], references: [id])
  reconciliationMatches ReconciliationMatch[]
  approvalRequests   ApprovalRequest[]
  evidenceDocuments  EvidenceDocument[]
  anomalyAlerts      AnomalyAlert[]

  @@index([tenant_id])
  @@index([tenant_id, transaction_date])
  @@index([tenant_id, posting_period])
  @@index([account_id])
  @@index([snapshot_id])
  @@index([ingestion_batch_id])
  @@map("ledger_entries")
}

model Vendor {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model CostCenter {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model TaxComponent {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  rate      Decimal  @db.Decimal(5, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model FxRate {
  id             String   @id @default(uuid())
  baseCurrency   String
  targetCurrency String
  rate           Decimal  @db.Decimal(19, 6)
  date           DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([baseCurrency, targetCurrency, date])
}

model IngestionBatch {
  id                String             @id @default(uuid())
  tenant_id         String
  source_type       String
  file_name         String
  record_count      Int                @default(0)
  status            String             @default("pending")
  createdBy         String?
  created_at        DateTime           @default(now())
  dataQualityIssues DataQualityIssue[]
  user              User?              @relation(fields: [createdBy], references: [id])
  tenant            Tenant             @relation(fields: [tenant_id], references: [id])
  files             IngestionFile[]
  rawRecords        RawRecord[]
  snapshots         Snapshot[]

  @@index([tenant_id])
  @@index([status])
  @@index([created_at])

  @@map("ingestion_batches")
}

model IngestionFile {
  id        String         @id @default(uuid())
  batch_id  String
  file_path String
  checksum  String
  batch     IngestionBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  @@map("ingestion_files")
}

model Snapshot {
  id                 String             @id @default(uuid())
  tenant_id          String
  batch_id           String
  status             String             @default("UNPROCESSED")
  snapshot_timestamp DateTime           @default(now())
  record_count       Int                @default(0)
  payload_hash       String             @default("")
  dataQualityIssues  DataQualityIssue[]
  changeEvents       ChangeEvent[]
  controlRuns        ControlRun[]
  rawRecords         RawRecord[]
  updatedAt          DateTime           @updatedAt
  graph_processed    Boolean            @default(false)
  batch              IngestionBatch     @relation(fields: [batch_id], references: [id])
  tenant             Tenant             @relation(fields: [tenant_id], references: [id])
  error_message      String?

  ledgerEntries      LedgerEntry[]
  evidenceDocuments  EvidenceDocument[]
  approvalRequests   ApprovalRequest[]

  @@map("snapshots")
}

model RawRecord {
  id               String         @id @default(uuid())
  batch_id         String
  payload_json     Json
  snapshotId       String?
  validationErrors Json?
  lineage_hash     String?  // SHA-256 for source integrity
  batch            IngestionBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  snapshot         Snapshot?      @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([batch_id])
  @@index([snapshotId])

  @@map("raw_records")
}

model ChangeEvent {
  id            String   @id @default(uuid())
  tenant_id     String
  entity_type   String   @default("RECORD")
  entity_id     String
  change_type   String
  old_value     Json?
  new_value     Json?
  snapshot_from String?
  snapshot_to   String
  detected_at   DateTime @default(now())
  snapshotTo    Snapshot @relation(fields: [snapshot_to], references: [id])
  tenant        Tenant   @relation(fields: [tenant_id], references: [id])

  @@map("change_events")
}

model DataQualityIssue {
  id              String         @id @default(uuid())
  tenantId        String
  batchId         String
  snapshotId      String
  issueType       String
  entityReference String?
  severity        String
  status          String         @default("OPEN")
  details         Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  batch           IngestionBatch @relation(fields: [batchId], references: [id])
  snapshot        Snapshot       @relation(fields: [snapshotId], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
}

model ControlSpec {
  id          String          @id @default(uuid())
  tenantId    String
  name        String
  description String?
  ruleType    String
  parameters  Json
  severity    String
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  results     ControlResult[]
}

model ControlRun {
  id            String          @id @default(uuid())
  tenantId      String
  snapshot_id   String
  status        String          @default("RUNNING")
  run_timestamp DateTime        @default(now())
  results       ControlResult[]
  snapshot      Snapshot        @relation(fields: [snapshot_id], references: [id])
  tenant        Tenant          @relation(fields: [tenantId], references: [id])

  @@map("control_runs")
}

model ControlResult {
  id                String           @id @default(uuid())
  controlRunId      String
  control_id        String
  entity_reference  String
  severity          String
  violation_message String
  confidence_score  String?
  created_at        DateTime         @default(now())
  overrides         ControlOverride?
  controlRun        ControlRun       @relation(fields: [controlRunId], references: [id])
  controlSpec       ControlSpec      @relation(fields: [control_id], references: [id])

  @@index([controlRunId])
  @@index([control_id])
  @@index([entity_reference])

  @@map("control_results")
}

model ControlOverride {
  id           String        @id @default(uuid())
  tenantId     String
  resultId     String        @unique
  approvedById String
  reason       String
  createdAt    DateTime      @default(now())
  approvedBy   User          @relation(fields: [approvedById], references: [id])
  result       ControlResult @relation(fields: [resultId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
}

model CloseCycle {
  id             String      @id @default(uuid())
  tenantId       String
  name           String
  startDate      DateTime
  endDate        DateTime
  close_deadline DateTime?
  status         String      @default("OPEN")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  tasks          CloseTask[]
}

model CloseTask {
  id                        String           @id @default(uuid())
  tenantId                  String
  cycleId                   String
  name                      String
  description               String?
  assignedRoleId            String?
  status                    String           @default("PENDING")
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  cycle                     CloseCycle       @relation(fields: [cycleId], references: [id])
  tenant                    Tenant           @relation(fields: [tenantId], references: [id])
  approvals                 TaskApproval[]
  dependenciesAsPredecessor TaskDependency[] @relation("PredecessorTask")
  dependenciesAsSuccessor   TaskDependency[] @relation("SuccessorTask")
  evidence                  TaskEvidence[]
}

model TaskDependency {
  id            String    @id @default(uuid())
  predecessorId String
  successorId   String
  createdAt     DateTime  @default(now())
  predecessor   CloseTask @relation("PredecessorTask", fields: [predecessorId], references: [id])
  successor     CloseTask @relation("SuccessorTask", fields: [successorId], references: [id])

  @@unique([predecessorId, successorId])
}

model TaskEvidence {
  id           String    @id @default(uuid())
  taskId       String
  uploadedById String
  fileName     String
  fileUrl      String
  createdAt    DateTime  @default(now())
  task         CloseTask @relation(fields: [taskId], references: [id])
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
}

model TaskApproval {
  id           String    @id @default(uuid())
  taskId       String
  approvedById String
  status       String
  comments     String?
  createdAt    DateTime  @default(now())
  approvedBy   User      @relation(fields: [approvedById], references: [id])
  task         CloseTask @relation(fields: [taskId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  userId     String?
  action     String
  entityType String?
  entityId   String?
  details    Json?
  hash       String?
  prevHash   String?
  createdAt  DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model RiskMetric {
  id            String   @id @default(uuid())
  tenant_id     String
  period        String
  journal_risk  Float    @default(0.0)
  tax_risk      Float    @default(0.0)
  override_risk Float    @default(0.0)
  close_risk    Float    @default(0.0)
  calculated_at DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, period])
  @@map("risk_metrics")
}

model GraphNode {
  id               String      @id @default(uuid())
  tenant_id        String
  node_type        String
  reference_id     String
  state_value      Json?
  last_computed_at DateTime?
  version          Int         @default(1)
  created_at       DateTime    @default(now())
  edges_out        GraphEdge[] @relation("sourceNode")
  edges_in         GraphEdge[] @relation("targetNode")
  tenant           Tenant      @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, node_type, reference_id])
  @@index([tenant_id])
  @@index([reference_id])
  @@map("graph_nodes")
}

model GraphEdge {
  id                String    @id @default(uuid())
  tenant_id         String
  source_node_id    String
  target_node_id    String
  relationship_type String
  created_at        DateTime  @default(now())
  sourceNode        GraphNode @relation("sourceNode", fields: [source_node_id], references: [id])
  targetNode        GraphNode @relation("targetNode", fields: [target_node_id], references: [id])
  tenant            Tenant    @relation(fields: [tenant_id], references: [id])

  @@unique([source_node_id, target_node_id, relationship_type])

  @@index([tenant_id])
  @@index([source_node_id])
  @@index([target_node_id])

  @@map("graph_edges")
}

model ErpConnector {
  id                String           @id @default(uuid())
  tenant_id         String
  connector_type    String
  connection_config Json
  sync_frequency    String           @default("DAILY")
  last_sync_at      DateTime?
  status            String           @default("ACTIVE")
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  tokens            ConnectorToken[]
  tenant            Tenant           @relation(fields: [tenant_id], references: [id])
  syncJobs          SyncJob[]

  @@unique([tenant_id, connector_type])
  @@map("erp_connectors")
}

model ConnectorToken {
  id           String       @id @default(uuid())
  connector_id String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime     @default(now())
  connector    ErpConnector @relation(fields: [connector_id], references: [id], onDelete: Cascade)

  @@map("connector_tokens")
}

model SyncJob {
  id            String       @id @default(uuid())
  tenant_id     String
  connector_id  String
  sync_type     String
  status        String       @default("PENDING")
  started_at    DateTime?
  completed_at  DateTime?
  error_message String?
  record_count  Int          @default(0)
  connector     ErpConnector @relation(fields: [connector_id], references: [id])
  tenant        Tenant       @relation(fields: [tenant_id], references: [id])
  logs          SyncLog[]

  @@map("sync_jobs")
}

model SyncLog {
  id        String   @id @default(uuid())
  job_id    String
  level     String
  message   String
  timestamp DateTime @default(now())
  syncJob   SyncJob  @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

model Entity {
  id        String            @id @default(uuid())
  tenantId  String
  name      String
  country   String
  currency  String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  childOf   EntityHierarchy[] @relation("ChildEntity")
  parentOf  EntityHierarchy[] @relation("ParentEntity")

  @@map("entities")
}

model EntityHierarchy {
  id           String  @id @default(uuid())
  parentId     String
  childId      String
  ownershipPct Decimal @db.Decimal(5, 4)
  child        Entity  @relation("ChildEntity", fields: [childId], references: [id])
  parent       Entity  @relation("ParentEntity", fields: [parentId], references: [id])

  @@unique([parentId, childId])
  @@map("entity_hierarchy")
}

model IntercompanyTransaction {
  id              String   @id @default(uuid())
  tenantId        String
  fromEntityId    String
  toEntityId      String
  amount          Decimal  @db.Decimal(19, 4)
  currency        String
  transactionDate DateTime
  description     String?
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@map("intercompany_transactions")
}

model EliminationJournal {
  id              String   @id @default(uuid())
  tenantId        String
  consolidationId String
  description     String
  amount          Decimal  @db.Decimal(19, 4)
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@map("elimination_journals")
}

model GstRecord {
  id              String   @id @default(uuid())
  tenantId        String
  gstin           String
  invoiceNum      String
  invoiceDate     DateTime
  hsnCode         String?
  taxableValue    Decimal  @db.Decimal(19, 4)
  igstAmount      Decimal  @default(0) @db.Decimal(19, 4)
  cgstAmount      Decimal  @default(0) @db.Decimal(19, 4)
  sgstAmount      Decimal  @default(0) @db.Decimal(19, 4)
  isReverseCharge Boolean  @default(false)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@map("gst_records")
}

model GstValidation {
  id           String   @id @default(uuid())
  tenantId     String
  entityType   String
  entityId     String
  status       String
  issueDetails Json?
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@map("gst_validations")
}

model VendorCompliance {
  id              String   @id @default(uuid())
  tenantId        String
  vendorName      String
  gstin           String
  filingStatus    String
  complianceScore Float    @default(0)
  lastChecked     DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@map("vendor_compliance")
}



model ForecastVersion {
  id        String   @id @default(uuid())
  tenantId  String
  budgetId  String
  name      String
  amount    Decimal  @db.Decimal(19, 4)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("forecast_versions")
}

model VarianceRecord {
  id          String   @id @default(uuid())
  tenantId    String
  period      String
  actual      Decimal  @db.Decimal(19, 4)
  budget      Decimal  @db.Decimal(19, 4)
  variance    Decimal  @db.Decimal(19, 4)
  explanation String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@map("variance_records")
}

model FinancialHealthIndex {
  id                    String   @id @default(uuid())
  tenant_id             String
  period                String
  integrity_component   Float    @default(0.0)
  governance_component  Float    @default(0.0)
  stability_component   Float    @default(0.0)
  performance_component Float    @default(0.0)
  final_score           Float    @default(0.0)
  calculated_at         DateTime @default(now())
  tenant                Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, period])
  @@map("financial_health_index")
}

model MaterializedLedgerMetric {
  id            String   @id @default(uuid())
  tenant_id     String
  metric_date   DateTime
  debit_total   Decimal  @db.Decimal(19, 4)
  credit_total  Decimal  @db.Decimal(19, 4)
  record_count  Int
  calculated_at DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, metric_date])
  @@map("materialized_ledger_metrics")
}

model BankAccount {
  id         String   @id @default(uuid())
  tenantId   String
  bankName   String
  accountNo  String
  currency   String
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  statements BankStatement[]

  @@index([tenantId])
}

model BankStatement {
  id            String   @id @default(uuid())
  tenantId      String
  bankAccountId String
  statementDate DateTime
  createdAt     DateTime @default(now())

  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  transactions  BankTransaction[]

  @@index([tenantId])
  @@index([statementDate])
}

model BankTransaction {
  id              String   @id @default(uuid())
  statementId     String
  transactionDate DateTime
  description     String
  amount          Decimal  @db.Decimal(19,4)
  currency        String
  reference       String?
  createdAt       DateTime @default(now())

  statement       BankStatement @relation(fields: [statementId], references: [id])
  matches         ReconciliationMatch[]

  @@index([transactionDate])
}

model ReconciliationSession {
  id            String   @id @default(uuid())
  tenantId      String
  status        String   @default("OPEN") // OPEN, COMMITTED, REJECTED
  period        String?
  source        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  matches       ReconciliationMatch[]

  @@index([tenantId])
  @@map("reconciliation_sessions")
}

model ReconciliationMatch {
  id                String   @id @default(uuid())
  tenantId          String
  sessionId         String?
  bankTransactionId String
  ledgerEntryId     String
  matchType         String
  confidence        Float
  rules_meta        Json?
  createdAt         DateTime @default(now())

  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  session           ReconciliationSession? @relation(fields: [sessionId], references: [id])
  bankTransaction   BankTransaction @relation(fields: [bankTransactionId], references: [id])
  ledgerEntry       LedgerEntry     @relation(fields: [ledgerEntryId], references: [id])

  @@index([tenantId])
  @@index([sessionId])
  @@map("reconciliation_matches")
}

model NetworkMetric {
  id            String   @id @default(uuid())
  industry      String
  company_size  String
  metric_name   String
  average_value Float
  percentile_25 Float
  percentile_50 Float
  percentile_75 Float
  percentile_95 Float
  calculated_at DateTime @default(now())

  @@unique([industry, company_size, metric_name, calculated_at])
  @@map("network_metrics")
}



model WorkflowRun {
  id           String         @id @default(uuid())
  tenant_id    String
  workflow_name String
  status       String         @default("PENDING")
  started_at   DateTime?
  completed_at DateTime?
  error_message String?
  metadata     Json?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  tenant       Tenant         @relation(fields: [tenant_id], references: [id])
  tasks        WorkflowTask[]

  @@map("workflow_runs")
}

model WorkflowTask {
  id              String                   @id @default(uuid())
  run_id          String
  task_name       String
  task_type       String
  status          String                   @default("PENDING")
  started_at      DateTime?
  completed_at    DateTime?
  retry_count     Int                      @default(0)
  max_retries     Int                      @default(3)
  error_message   String?
  input_data      Json?
  output_data     Json?
  run             WorkflowRun              @relation(fields: [run_id], references: [id], onDelete: Cascade)
  dependenciesAsPredecessor WorkflowTaskDependency[] @relation("TaskPredecessor")
  dependenciesAsSuccessor   WorkflowTaskDependency[] @relation("TaskSuccessor")

  @@map("workflow_tasks")
}

model WorkflowTaskDependency {
  id            String       @id @default(uuid())
  predecessorId String
  successorId   String
  predecessor   WorkflowTask @relation("TaskPredecessor", fields: [predecessorId], references: [id])
  successor     WorkflowTask @relation("TaskSuccessor", fields: [successorId], references: [id])

  @@unique([predecessorId, successorId])
  @@map("workflow_task_dependencies")
}

model JobDefinition {
  id             String   @id @default(uuid())
  tenant_id      String
  name           String
  workflow_name  String
  cron_schedule  String
  last_run_at    DateTime?
  next_run_at    DateTime?
  is_active      Boolean  @default(true)
  config         Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenant_id], references: [id])

  @@map("job_definitions")
}

model SchemaRegistry {
  id            String   @id @default(uuid())
  tenant_id     String
  entity_type   String   // e.g., "LedgerEntry", "Invoice"
  schema_json   Json
  version       Int      @default(1)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, entity_type, version])
  @@map("schema_registry")
}

model AccountMap {
  id              String   @id @default(uuid())
  tenant_id       String
  source_system   String
  source_code     String
  target_account_id String
  confidence_score Int      @default(100)
  is_manual       Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenant_id], references: [id])
  targetAccount   Account  @relation(fields: [target_account_id], references: [id])

  @@unique([tenant_id, source_system, source_code])
  @@map("account_maps")
}

model ConditioningLog {
  id              String   @id @default(uuid())
  tenant_id       String
  run_id          String?
  entity_type     String
  entity_id       String
  original_value  Json?
  applied_fix     String
  confidence_delta Int
  created_at      DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenant_id], references: [id])

  @@map("conditioning_logs")
}

model LineageTrail {
  id              String   @id @default(uuid())
  tenant_id       String
  child_type      String   // e.g., "LedgerEntry"
  child_id        String
  parent_type     String   // e.g., "RawRecord"
  parent_id       String
  transformation  String   // Name of the rule applied
  created_at      DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([parent_id])
  @@map("lineage_trails")
}

model PeriodLock {
  id          String   @id @default(uuid())
  tenantId    String
  periodName  String   // e.g., "2024-03" or "2024-Q1"
  isLocked    Boolean  @default(false)
  lockedAt    DateTime?
  lockedById  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  lockedBy    User?    @relation("PeriodLockedBy", fields: [lockedById], references: [id])

  @@unique([tenantId, periodName])
  @@map("period_locks")
}

model IntegritySeal {
  id            String   @id @default(uuid())
  tenantId      String
  batchId       String   @unique
  sealHash      String   // SHA-256 Merkle Root
  sealedAt      DateTime @default(now())
  sealedById    String?
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  sealedBy      User?    @relation("SealedBy", fields: [sealedById], references: [id])

  @@index([tenantId])
  @@map("integrity_seals")
}

model TaxJurisdiction {
  id           String    @id @default(uuid())
  tenantId     String
  name         String    // e.g., "India", "UK", "California"
  countryCode  String
  currency     String
  isDefault    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  taxRates     TaxRate[]

  @@unique([tenantId, countryCode, name])
  @@map("tax_jurisdictions")
}

model TaxRate {
  id              String   @id @default(uuid())
  jurisdictionId  String
  taxCode         String   // e.g., "GST_18", "VAT_20"
  taxType         String   // VAT, GST, SalesTax
  rate            Decimal  @db.Decimal(19, 4)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jurisdiction    TaxJurisdiction @relation(fields: [jurisdictionId], references: [id])

  @@unique([jurisdictionId, taxCode])
  @@map("tax_rates")
}

model ApprovalWorkflow {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  steps_count Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  requests    ApprovalRequest[]

  @@map("approval_workflows")
}

model ApprovalRequest {
  id            String   @id @default(uuid())
  tenantId      String
  workflowId    String
  entityType    String   // "LedgerEntry", "Snapshot"
  entityId      String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedById String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  workflow      ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  requestedBy   User             @relation("RequestedBy", fields: [requestedById], references: [id])
  steps         ApprovalStep[]
  
  ledgerEntry   LedgerEntry?     @relation(fields: [entityId], references: [id], map: "ApprovalRequestLedgerEntry")
  snapshot      Snapshot?        @relation(fields: [entityId], references: [id], map: "ApprovalRequestSnapshot")

  @@map("approval_requests")
}

model ApprovalStep {
  id          String   @id @default(uuid())
  requestId   String
  stepOrder   Int
  status      String   @default("PENDING")
  approverId  String?
  comments    String?
  actionedAt  DateTime?
  createdAt   DateTime @default(now())

  request     ApprovalRequest @relation(fields: [requestId], references: [id])
  approver    User?           @relation("Approver", fields: [approverId], references: [id])

  @@map("approval_steps")
}

model EvidenceDocument {
  id                String   @id @default(uuid())
  tenantId          String
  entityType        String   // "LedgerEntry", "Snapshot"
  entityId          String
  fileName          String
  fileType          String
  fileUrl           String   // S3/Cloud storage reference
  digitalSignature  String?  // SHA-256 hash of file content
  version           Int      @default(1)
  previousVersionId String?  @unique
  uploadedById      String?
  uploadedAt        DateTime @default(now())

  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  uploadedBy        User?    @relation(fields: [uploadedById], references: [id])
  ledgerEntry       LedgerEntry? @relation(fields: [entityId], references: [id], map: "EvidenceLedgerEntry")
  snapshot          Snapshot?    @relation(fields: [entityId], references: [id], map: "EvidenceSnapshot")
  
  previousVersion   EvidenceDocument? @relation("EvidenceHistory", fields: [previousVersionId], references: [id])
  nextVersion       EvidenceDocument? @relation("EvidenceHistory")

  @@map("evidence_documents")
}

model AnomalyAlert {
  id              String   @id @default(uuid())
  tenantId        String
  ledgerEntryId   String
  confidenceScore Float
  reasoning       String
  severity        String   // LOW, MEDIUM, HIGH, CRITICAL
  status          String   @default("OPEN") // OPEN, INVESTIGATING, RESOLVED, FALSE_POSITIVE
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  ledgerEntry     LedgerEntry   @relation(fields: [ledgerEntryId], references: [id])
  investigations  Investigation[]

  @@map("anomaly_alerts")
}

model Investigation {
  id              String   @id @default(uuid())
  tenantId        String
  alertId         String
  assignedTo      String?
  findings        String?
  resolution      String?
  status          String   @default("OPEN")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  alert           AnomalyAlert  @relation(fields: [alertId], references: [id])
  assignee        User?         @relation("InvestigationAssignee", fields: [assignedTo], references: [id])

  @@map("investigations")
}

model Budget {
  id          String       @id @default(uuid())
  tenantId    String
  name        String
  fiscalYear  Int
  status      String       @default("DRAFT") // DRAFT, ACTIVE, ARCHIVED
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  items       BudgetItem[]

  @@map("budgets")
}

model BudgetItem {
  id         String   @id @default(uuid())
  budgetId   String
  accountId  String
  amount     Decimal  @db.Decimal(19, 4)
  period     String?  // Optional: "Q1", "JAN", etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  budget     Budget   @relation(fields: [budgetId], references: [id])
  account    Account  @relation(fields: [accountId], references: [id])

  @@map("budget_items")
}
