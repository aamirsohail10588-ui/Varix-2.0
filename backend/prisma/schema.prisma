generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company_size String?  @default("Mid-Market")
  industry     String?  @default("Technology")
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  password         String
  name             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  googleId         String?           @unique
  mfaEnabled       Boolean           @default(false)
  mfaSecret        String?
  microsoftId      String?           @unique
  auditLogs        AuditLog[]
  controlOverrides ControlOverride[]
  taskApprovals    TaskApproval[]
  taskEvidence     TaskEvidence[]
  tenants          UserTenantRole[]
  ingestionBatches IngestionBatch[]
  sessions         Session[]
}

model Role {
  id          String           @id @default(uuid())
  name        String
  tenantId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  description String?
  permissions RolePermission[]
  users       UserTenantRole[]

  @@unique([name, tenantId])
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserTenantRole {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      Role     @relation(fields: [roleId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId, roleId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  tenantId     String?  @db.Uuid
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  deviceMeta   Json?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model ApiKey {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  keyHash   String    @unique
  prefix    String
  scopes    String[]  @default(["read"])
  expiresAt DateTime?
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  @@map("api_keys")
}

model ServiceAccount {
  id         String   @id @default(uuid())
  tenantId   String   @db.Uuid
  name       String
  clientId   String   @unique
  secretHash String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("service_accounts")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Account {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
}

model LedgerEntry {
  id                   String    @default(uuid()) @db.Uuid
  tenant_id            String    @db.Uuid
  transaction_date     DateTime  @db.Timestamp(6)
  posting_period       String?
  account_id           String?   @db.Uuid
  debit_amount         Decimal?  @db.Decimal(19, 4)
  credit_amount        Decimal?  @db.Decimal(19, 4)
  currency             String?
  source_system        String?
  snapshot_id          String?   @db.Uuid
  ingestion_batch_id   String?   @db.Uuid
  confidence_score     Int?
  source_id            String?
  createdAt            DateTime? @default(now()) @db.Timestamp(6)
  provenance_hash      String?
  base_currency_amount Decimal?  @default(0.0) @db.Decimal(19, 4)
  tax_code             String?
  tax_amount           Decimal?  @default(0.0) @db.Decimal(19, 4)
  tax_rate_id          String?   @db.Uuid

  @@id([id, transaction_date], map: "ledger_entries_pkey1")
  @@index([snapshot_id], map: "idx_ledger_snapshot")
  @@index([tenant_id], map: "idx_ledger_tenant")
  @@map("ledger_entries")
}

model Vendor {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CostCenter {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
}

model TaxComponent {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  rate      Decimal  @db.Decimal(5, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
}

model FxRate {
  id             String   @id @default(uuid())
  baseCurrency   String
  targetCurrency String
  rate           Decimal  @db.Decimal(19, 6)
  date           DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([baseCurrency, targetCurrency, date])
}

model IngestionBatch {
  id                String             @id @default(uuid())
  tenant_id         String
  source_type       String
  file_name         String
  record_count      Int                @default(0)
  status            String             @default("pending")
  created_at        DateTime           @default(now())
  createdBy         String?
  dataQualityIssues DataQualityIssue[]
  user              User?              @relation(fields: [createdBy], references: [id])
  files             IngestionFile[]
  rawRecords        RawRecord[]
  snapshots         Snapshot[]

  @@index([tenant_id])
  @@index([status])
  @@index([created_at])
  @@map("ingestion_batches")
}

model IngestionFile {
  id        String         @id @default(uuid())
  batch_id  String
  file_path String
  checksum  String
  batch     IngestionBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  @@map("ingestion_files")
}

model Snapshot {
  id                 String             @id @default(uuid())
  tenant_id          String             @db.Uuid
  batch_id           String
  status             String             @default("UNPROCESSED")
  snapshot_timestamp DateTime           @default(now())
  record_count       Int                @default(0)
  payload_hash       String             @default("")
  graph_processed    Boolean            @default(false)
  updatedAt          DateTime           @updatedAt
  error_message      String?
  dataQualityIssues  DataQualityIssue[]
  changeEvents       ChangeEvent[]
  controlRuns        ControlRun[]
  rawRecords         RawRecord[]
  batch              IngestionBatch     @relation(fields: [batch_id], references: [id])

  @@map("snapshots")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model RawRecord {
  id               String         @id @default(uuid())
  batch_id         String
  payload_json     Json
  snapshotId       String?
  validationErrors Json?
  lineage_hash     String?
  batch            IngestionBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  snapshot         Snapshot?      @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([batch_id])
  @@index([snapshotId])
  @@map("raw_records")
}

model ChangeEvent {
  id            String   @id @default(uuid())
  tenant_id     String
  entity_type   String   @default("RECORD")
  entity_id     String
  change_type   String
  old_value     Json?
  new_value     Json?
  snapshot_from String?
  snapshot_to   String
  detected_at   DateTime @default(now())
  snapshotTo    Snapshot @relation(fields: [snapshot_to], references: [id])

  @@map("change_events")
}

model DataQualityIssue {
  id              String         @id @default(uuid())
  tenantId        String
  batchId         String
  snapshotId      String
  issueType       String
  entityReference String?
  severity        String
  status          String         @default("OPEN")
  details         Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  batch           IngestionBatch @relation(fields: [batchId], references: [id])
  snapshot        Snapshot       @relation(fields: [snapshotId], references: [id])
}

model ControlSpec {
  id          String          @id @default(uuid())
  tenantId    String
  name        String
  description String?
  ruleType    String
  parameters  Json
  severity    String
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  results     ControlResult[]
}

model ControlRun {
  id            String          @id @default(uuid())
  tenantId      String
  snapshot_id   String
  status        String          @default("RUNNING")
  run_timestamp DateTime        @default(now())
  results       ControlResult[]
  snapshot      Snapshot        @relation(fields: [snapshot_id], references: [id])

  @@map("control_runs")
}

model ControlResult {
  id                String           @id @default(uuid())
  controlRunId      String
  control_id        String
  entity_reference  String
  severity          String
  violation_message String
  created_at        DateTime         @default(now())
  confidence_score  String?
  overrides         ControlOverride?
  controlRun        ControlRun       @relation(fields: [controlRunId], references: [id])
  controlSpec       ControlSpec      @relation(fields: [control_id], references: [id])

  @@index([controlRunId])
  @@index([control_id])
  @@index([entity_reference])
  @@map("control_results")
}

model ControlOverride {
  id           String        @id @default(uuid())
  tenantId     String
  resultId     String        @unique
  approvedById String
  reason       String
  createdAt    DateTime      @default(now())
  approvedBy   User          @relation(fields: [approvedById], references: [id])
  result       ControlResult @relation(fields: [resultId], references: [id])
}

model CloseCycle {
  id             String      @id @default(uuid())
  tenantId       String
  name           String
  startDate      DateTime
  endDate        DateTime
  status         String      @default("OPEN")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  close_deadline DateTime?
  tasks          CloseTask[]
}

model CloseTask {
  id                        String           @id @default(uuid())
  tenantId                  String
  cycleId                   String
  name                      String
  description               String?
  assignedRoleId            String?
  status                    String           @default("PENDING")
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  cycle                     CloseCycle       @relation(fields: [cycleId], references: [id])
  approvals                 TaskApproval[]
  dependenciesAsPredecessor TaskDependency[] @relation("PredecessorTask")
  dependenciesAsSuccessor   TaskDependency[] @relation("SuccessorTask")
  evidence                  TaskEvidence[]
}

model TaskDependency {
  id            String    @id @default(uuid())
  predecessorId String
  successorId   String
  createdAt     DateTime  @default(now())
  predecessor   CloseTask @relation("PredecessorTask", fields: [predecessorId], references: [id])
  successor     CloseTask @relation("SuccessorTask", fields: [successorId], references: [id])

  @@unique([predecessorId, successorId])
}

model TaskEvidence {
  id           String    @id @default(uuid())
  taskId       String
  uploadedById String
  fileName     String
  fileUrl      String
  createdAt    DateTime  @default(now())
  task         CloseTask @relation(fields: [taskId], references: [id])
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
}

model TaskApproval {
  id           String    @id @default(uuid())
  taskId       String
  approvedById String
  status       String
  comments     String?
  createdAt    DateTime  @default(now())
  approvedBy   User      @relation(fields: [approvedById], references: [id])
  task         CloseTask @relation(fields: [taskId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  userId     String?
  action     String
  entityType String?
  entityId   String?
  details    Json?
  hash       String?
  prevHash   String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model RiskMetric {
  id            String   @id @default(uuid())
  tenant_id     String   @db.Uuid
  period        String
  journal_risk  Float    @default(0.0)
  tax_risk      Float    @default(0.0)
  override_risk Float    @default(0.0)
  close_risk    Float    @default(0.0)
  calculated_at DateTime @default(now())

  @@unique([tenant_id, period])
  @@map("risk_metrics")
}

model GraphNode {
  id               String      @id @default(uuid())
  tenant_id        String
  node_type        String
  reference_id     String
  created_at       DateTime    @default(now())
  last_computed_at DateTime?
  state_value      Json?
  version          Int         @default(1)
  edges_out        GraphEdge[] @relation("sourceNode")
  edges_in         GraphEdge[] @relation("targetNode")

  @@unique([tenant_id, node_type, reference_id])
  @@index([tenant_id])
  @@index([reference_id])
  @@map("graph_nodes")
}

model GraphEdge {
  id                String    @id @default(uuid())
  tenant_id         String
  source_node_id    String
  target_node_id    String
  relationship_type String
  created_at        DateTime  @default(now())
  sourceNode        GraphNode @relation("sourceNode", fields: [source_node_id], references: [id])
  targetNode        GraphNode @relation("targetNode", fields: [target_node_id], references: [id])

  @@unique([source_node_id, target_node_id, relationship_type])
  @@index([tenant_id])
  @@index([source_node_id])
  @@index([target_node_id])
  @@map("graph_edges")
}

model ErpConnector {
  id                String           @id @default(uuid())
  tenant_id         String
  connector_type    String
  connection_config Json
  sync_frequency    String           @default("DAILY")
  last_sync_at      DateTime?
  status            String           @default("ACTIVE")
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  tokens            ConnectorToken[]
  syncJobs          SyncJob[]

  @@unique([tenant_id, connector_type])
  @@map("erp_connectors")
}

model ConnectorToken {
  id           String       @id @default(uuid())
  connector_id String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime     @default(now())
  connector    ErpConnector @relation(fields: [connector_id], references: [id], onDelete: Cascade)

  @@map("connector_tokens")
}

model SyncJob {
  id            String       @id @default(uuid())
  tenant_id     String       @db.Uuid
  connector_id  String
  sync_type     String
  status        String       @default("PENDING")
  started_at    DateTime?
  completed_at  DateTime?
  error_message String?
  record_count  Int          @default(0)
  connector     ErpConnector @relation(fields: [connector_id], references: [id])
  logs          SyncLog[]

  @@map("sync_jobs")
}

model SyncLog {
  id        String   @id @default(uuid())
  job_id    String
  level     String
  message   String
  timestamp DateTime @default(now())
  syncJob   SyncJob  @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

model Entity {
  id        String            @id @default(uuid())
  tenantId  String
  name      String
  country   String
  currency  String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  childOf   EntityHierarchy[] @relation("ChildEntity")
  parentOf  EntityHierarchy[] @relation("ParentEntity")

  @@map("entities")
}

model EntityHierarchy {
  id           String  @id @default(uuid())
  parentId     String
  childId      String
  ownershipPct Decimal @db.Decimal(5, 4)
  child        Entity  @relation("ChildEntity", fields: [childId], references: [id])
  parent       Entity  @relation("ParentEntity", fields: [parentId], references: [id])

  @@unique([parentId, childId])
  @@map("entity_hierarchy")
}

model IntercompanyTransaction {
  id              String   @id @default(uuid())
  tenantId        String
  fromEntityId    String
  toEntityId      String
  amount          Decimal  @db.Decimal(19, 4)
  currency        String
  transactionDate DateTime
  description     String?

  @@map("intercompany_transactions")
}

model EliminationJournal {
  id              String   @id @default(uuid())
  tenantId        String
  consolidationId String
  description     String
  amount          Decimal  @db.Decimal(19, 4)
  createdAt       DateTime @default(now())

  @@map("elimination_journals")
}

model GstRecord {
  id              String   @id @default(uuid())
  tenantId        String
  gstin           String
  invoiceNum      String
  invoiceDate     DateTime
  hsnCode         String?
  taxableValue    Decimal  @db.Decimal(19, 4)
  igstAmount      Decimal  @default(0) @db.Decimal(19, 4)
  cgstAmount      Decimal  @default(0) @db.Decimal(19, 4)
  sgstAmount      Decimal  @default(0) @db.Decimal(19, 4)
  isReverseCharge Boolean  @default(false)

  @@map("gst_records")
}

model GstValidation {
  id           String   @id @default(uuid())
  tenantId     String
  entityType   String
  entityId     String
  status       String
  issueDetails Json?
  createdAt    DateTime @default(now())

  @@map("gst_validations")
}

model VendorCompliance {
  id              String   @id @default(uuid())
  tenantId        String   @db.Uuid
  vendorName      String
  gstin           String
  filingStatus    String
  complianceScore Float    @default(0)
  lastChecked     DateTime @default(now())

  @@map("vendor_compliance")
}

model ForecastVersion {
  id        String   @id @default(uuid())
  tenantId  String
  budgetId  String
  name      String
  amount    Decimal  @db.Decimal(19, 4)
  createdAt DateTime @default(now())

  @@map("forecast_versions")
}

model VarianceRecord {
  id          String   @id @default(uuid())
  tenantId    String   @db.Uuid
  period      String
  actual      Decimal  @db.Decimal(19, 4)
  budget      Decimal  @db.Decimal(19, 4)
  variance    Decimal  @db.Decimal(19, 4)
  explanation String?
  createdAt   DateTime @default(now())

  @@map("variance_records")
}

model FinancialHealthIndex {
  id                    String   @id @default(uuid())
  tenant_id             String
  period                String
  integrity_component   Float    @default(0.0)
  final_score           Float    @default(0.0)
  calculated_at         DateTime @default(now())
  governance_component  Float    @default(0.0)
  performance_component Float    @default(0.0)
  stability_component   Float    @default(0.0)

  @@unique([tenant_id, period])
  @@map("financial_health_index")
}

model MaterializedLedgerMetric {
  id            String   @id @default(uuid())
  tenant_id     String   @db.Uuid
  metric_date   DateTime
  debit_total   Decimal  @db.Decimal(19, 4)
  credit_total  Decimal  @db.Decimal(19, 4)
  record_count  Int
  calculated_at DateTime @default(now())

  @@unique([tenant_id, metric_date])
  @@map("materialized_ledger_metrics")
}

model BankAccount {
  id         String          @id @default(uuid())
  tenantId   String
  bankName   String
  accountNo  String
  currency   String
  createdAt  DateTime        @default(now())
  statements BankStatement[]

  @@index([tenantId])
}

model BankStatement {
  id            String            @id @default(uuid())
  tenantId      String
  bankAccountId String
  statementDate DateTime
  createdAt     DateTime          @default(now())
  bankAccount   BankAccount       @relation(fields: [bankAccountId], references: [id])
  transactions  BankTransaction[]

  @@index([tenantId])
  @@index([statementDate])
}

model BankTransaction {
  id              String                @id @default(uuid())
  statementId     String
  transactionDate DateTime
  description     String
  amount          Decimal               @db.Decimal(19, 4)
  currency        String
  reference       String?
  createdAt       DateTime              @default(now())
  statement       BankStatement         @relation(fields: [statementId], references: [id])
  matches         ReconciliationMatch[]

  @@index([transactionDate])
}

model ReconciliationSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  status    String   @default("OPEN")
  period    String?
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reconciliation_sessions")
}

model ReconciliationMatch {
  id                String          @id(map: "ReconciliationMatch_pkey") @default(uuid())
  tenantId          String          @db.Uuid
  bankTransactionId String
  ledgerEntryId     String          @db.Uuid
  matchType         String
  confidence        Float
  createdAt         DateTime        @default(now())
  ledgerEntryDate   DateTime?       @db.Timestamp(6)
  sessionId         String?         @db.Uuid
  rules_meta        Json?
  bankTransaction   BankTransaction @relation(fields: [bankTransactionId], references: [id], map: "ReconciliationMatch_bankTransactionId_fkey")

  @@index([tenantId], map: "ReconciliationMatch_tenantId_idx")
  @@index([sessionId], map: "reconciliation_matches_sessionid_idx")
  @@map("reconciliation_matches")
}

model NetworkMetric {
  id            String   @id @default(uuid())
  industry      String
  company_size  String
  metric_name   String
  average_value Float
  percentile_25 Float
  percentile_50 Float
  percentile_75 Float
  percentile_95 Float
  calculated_at DateTime @default(now())

  @@unique([industry, company_size, metric_name, calculated_at])
  @@map("network_metrics")
}

model WorkflowRun {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  workflow_name String
  status        String    @default("PENDING")
  started_at    DateTime? @db.Timestamptz(6)
  completed_at  DateTime? @db.Timestamptz(6)
  error_message String?
  metadata      Json?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("workflow_runs")
}

model WorkflowTask {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  run_id        String    @db.Uuid
  task_name     String
  task_type     String
  status        String    @default("PENDING")
  started_at    DateTime? @db.Timestamptz(6)
  completed_at  DateTime? @db.Timestamptz(6)
  retry_count   Int?      @default(0)
  max_retries   Int?      @default(3)
  error_message String?
  input_data    Json?
  output_data   Json?

  @@map("workflow_tasks")
}

model WorkflowTaskDependency {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  predecessorId String @db.Uuid
  successorId   String @db.Uuid

  @@unique([predecessorId, successorId])
  @@map("workflow_task_dependencies")
}

model JobDefinition {
  id            String    @id @default(uuid())
  tenant_id     String
  name          String
  workflow_name String
  cron_schedule String
  last_run_at   DateTime?
  next_run_at   DateTime?
  is_active     Boolean   @default(true)
  config        Json?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@map("job_definitions")
}

model SchemaRegistry {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String    @db.Uuid
  entity_type String
  schema_json Json
  version     Int?      @default(1)
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([tenant_id, entity_type, version])
  @@map("schema_registry")
}

model AccountMap {
  id                String   @id @default(uuid())
  tenant_id         String
  source_system     String
  source_code       String
  target_account_id String
  confidence_score  Int      @default(100)
  is_manual         Boolean  @default(false)
